<Page
    x:Class="WDCableWUI.UI.Audio.AudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="AudioCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
                <TextBlock x:Uid="Audio_Title"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock x:Uid="Audio_Description"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <Border Style="{StaticResource AudioCardStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                          Glyph="&#xE767;"
                                          FontSize="20"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock x:Uid="Audio_Link_Title"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            </StackPanel>

                            <InfoBar x:Name="AudioInfoBar"
                                     IsOpen="False"
                                     Severity="Informational"
                                     IsClosable="False"/>

                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ComboBox x:Name="ModeComboBox"
                                          Grid.Row="0"
                                          Grid.Column="0"
                                          x:Uid="Audio_Mode_Header"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="ModeComboBox_SelectionChanged">
                                    <ComboBoxItem x:Uid="Audio_Mode_Send" Tag="send"/>
                                    <ComboBoxItem x:Uid="Audio_Mode_Receive" Tag="receive"/>
                                </ComboBox>

                                <ComboBox x:Name="SourceComboBox"
                                          Grid.Row="0"
                                          Grid.Column="1"
                                          x:Uid="Audio_Source_Header"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem x:Uid="Audio_Source_SystemAudio" Tag="systemAudio"/>
                                    <ComboBoxItem x:Uid="Audio_Source_Microphone" Tag="microphone" IsEnabled="False"/>
                                </ComboBox>

                                <ComboBox x:Name="EncodingComboBox"
                                          Grid.Row="0"
                                          Grid.Column="2"
                                          x:Uid="Audio_Encoding_Header"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False">
                                    <ComboBoxItem x:Name="EncodingOptionItem" Content="Opus 32 kbps" Tag="opus"/>
                                </ComboBox>

                                <ComboBox x:Name="LatencyComboBox"
                                          Grid.Row="0"
                                          Grid.Column="3"
                                          x:Uid="Audio_Latency_Header"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="LatencyComboBox_SelectionChanged">
                                    <ComboBoxItem x:Uid="Audio_Latency_Low" Tag="lowLatency"/>
                                    <ComboBoxItem x:Uid="Audio_Latency_Stable" Tag="stable"/>
                                </ComboBox>

                                <ComboBox x:Name="QualityComboBox"
                                          Grid.Row="1"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          x:Uid="Audio_Quality_Header"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="QualityComboBox_SelectionChanged">
                                    <ComboBoxItem x:Uid="Audio_Quality_Standard" Tag="standard"/>
                                    <ComboBoxItem x:Uid="Audio_Quality_Balanced" Tag="balanced"/>
                                    <ComboBoxItem x:Uid="Audio_Quality_High" Tag="high"/>
                                    <ComboBoxItem x:Uid="Audio_Quality_NearLossless" Tag="nearLossless"/>
                                </ComboBox>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="StartButton"
                                            x:Uid="Audio_Start_Button"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="StartButton_Click"/>
                                    <Button x:Name="StopButton"
                                            x:Uid="Audio_Stop_Button"
                                            IsEnabled="False"
                                            Click="StopButton_Click"/>
                                    <Button x:Name="RefreshButton"
                                            x:Uid="Audio_Refresh_Button"
                                            Click="RefreshButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AudioCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon x:Name="StateIcon"
                                      Grid.Column="0"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE783;"
                                      FontSize="20"
                                      Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                      VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="4">
                                <TextBlock x:Name="StateText"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Text="Idle"/>
                                <TextBlock x:Name="StateDetailsText"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Text="Audio Link is idle"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource AudioCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE9D9;"
                                      FontSize="20"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock x:Uid="Audio_Stats_Title"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>

                        <Grid RowSpacing="10" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" x:Uid="Audio_Stats_Latency" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="LatencyText" Grid.Row="0" Grid.Column="1" Text="Low latency" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="1" x:Uid="Audio_Stats_Quality" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="QualityText" Grid.Row="1" Grid.Column="1" Text="Standard 32 kbps" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="2" x:Uid="Audio_Stats_ConfiguredBitrate" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="ConfiguredBitrateText" Grid.Row="2" Grid.Column="1" Text="32.0 kbps" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="3" x:Uid="Audio_Stats_MeasuredBitrate" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="BitrateText" Grid.Row="3" Grid.Column="1" Text="0 bps" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="4" Text="Buffer" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="BufferText" Grid.Row="4" Grid.Column="1" Text="0 ms" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="5" Text="Sent" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="FramesSentText" Grid.Row="5" Grid.Column="1" Text="0" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="6" Text="Received" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="FramesReceivedText" Grid.Row="6" Grid.Column="1" Text="0" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="7" Text="Dropped" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="DroppedText" Grid.Row="7" Grid.Column="1" Text="0" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="8" Text="Underflows" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="UnderflowText" Grid.Row="8" Grid.Column="1" Text="0" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="9" Text="Packet loss" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="PacketLossText" Grid.Row="9" Grid.Column="1" Text="0" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="10" Text="Late drops" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="LateDropsText" Grid.Row="10" Grid.Column="1" Text="0" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="11" Text="PLC" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="PlcText" Grid.Row="11" Grid.Column="1" Text="0" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="12" Text="RTCP loss" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="RtcpLossText" Grid.Row="12" Grid.Column="1" Text="0%" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="13" Text="RTCP jitter" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="RtcpJitterText" Grid.Row="13" Grid.Column="1" Text="0 ms" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                            <TextBlock Grid.Row="14" Text="RTT" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="RttText" Grid.Row="14" Grid.Column="1" Text="-" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
